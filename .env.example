# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: change the model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: customize the system prompt
SYSTEM_PROMPT=You are a helpful assistant. Be concise, friendly, and clear. Format answers using Markdown when it improves readability.

# Optional: max number of past messages kept per user for conversation memory
MAX_HISTORY_MESSAGES=20
