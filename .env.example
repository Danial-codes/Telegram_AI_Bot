# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: change the model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: customize the system prompt
SYSTEM_PROMPT=You are a helpful assistant. Be concise, friendly, and clear. Format answers using Markdown when it improves readability.

# Optional: max number of past messages kept per user for conversation memory
MAX_HISTORY_MESSAGES=20

# Optional: OpenAI-compatible base URL.
# Leave empty to use the official OpenAI endpoint.
# Set this when using Azure OpenAI, Together, Ollama, vLLM, LiteLLM, etc.
# Example: https://api.together.xyz/v1  or  http://localhost:11434/v1
OPENAI_BASE_URL=

# Optional: Telegram Bot API base URL.
# Leave empty to use the official https://api.telegram.org/bot endpoint.
# Set this when self-hosting the Telegram Bot API server or pointing at a
# staging / mock server.
# Example: http://localhost:8081
TELEGRAM_BASE_URL=

# Optional: separate Telegram file endpoint.
# When omitted, falls back to TELEGRAM_BASE_URL (and ultimately to the default).
TELEGRAM_BASE_FILE_URL=
